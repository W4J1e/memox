<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Landing page: category entries. Only visible in "root" mode. -->
        <LinearLayout
            android:id="@+id/SettingsLanding"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/GoToAppearance"
                style="@style/Preference"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/appearance" />

            <TextView
                android:id="@+id/GoToBackup"
                style="@style/Preference"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/backup" />

            <TextView
                android:id="@+id/GoToData"
                style="@style/Preference"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/data" />

            <TextView
                android:id="@+id/GoToAbout"
                style="@style/Preference"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/about" />
        </LinearLayout>

        <!-- Appearance category -->
        <LinearLayout
            android:id="@+id/SectionAppearance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                style="@style/PreferenceHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/appearance" />

            <include
                android:id="@+id/View"
                layout="@layout/preference" />

            <include
                android:id="@+id/Theme"
                layout="@layout/preference" />

            <include
                android:id="@+id/DateFormatOverview"
                layout="@layout/preference" />

            <include
                android:id="@+id/DateFormatNoteView"
                layout="@layout/preference" />

            <include
                android:id="@+id/TextSize"
                layout="@layout/preference_seekbar" />

            <include
                android:id="@+id/TextSizeOverview"
                layout="@layout/preference_seekbar" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider" />

            <TextView
                style="@style/PreferenceHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/behaviour" />

            <include
                android:id="@+id/NotesSortOrder"
                layout="@layout/preference" />

            <include
                android:id="@+id/CheckedListItemSorting"
                layout="@layout/preference" />

            <include
                android:id="@+id/StartView"
                layout="@layout/preference" />

            <include
                android:id="@+id/DefaultListNoteViewMode"
                layout="@layout/preference" />

            <include
                android:id="@+id/AutoEmptyBin"
                layout="@layout/preference_stepper" />

            <include
                android:id="@+id/MaxLabels"
                layout="@layout/preference_stepper" />

            <include
                android:id="@+id/LabelsHiddenInOverview"
                layout="@layout/preference" />
        </LinearLayout>

        <!-- Backup category (manual + auto backups merged) -->
        <LinearLayout
            android:id="@+id/SectionBackup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                style="@style/PreferenceHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/backup" />

            <TextView
                android:id="@+id/ImportBackup"
                style="@style/Preference"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/import_backup" />

            <TextView
                android:id="@+id/ImportOther"
                style="@style/Preference"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/import_other" />

            <TextView
                android:id="@+id/ExportBackup"
                style="@style/Preference"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/export_backup" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider" />

            <TextView
                style="@style/PreferenceHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auto_backup" />

            <include
                android:id="@+id/BackupsFolder"
                layout="@layout/preference" />

            <include
                android:id="@+id/BackupOnSave"
                layout="@layout/preference" />

            <include
                android:id="@+id/PeriodicBackups"
                layout="@layout/preference" />

            <TextView
                android:id="@+id/PeriodicBackupLastExecution"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <include
                android:id="@+id/PeriodicBackupsPeriodInDays"
                layout="@layout/preference_stepper" />

            <include
                android:id="@+id/PeriodicBackupsMax"
                layout="@layout/preference_stepper" />
        </LinearLayout>

        <!-- Data category (security + settings) -->
        <LinearLayout
            android:id="@+id/SectionData"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                style="@style/PreferenceHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/navigation" />

            <TextView
                android:id="@+id/GoToDeleted"
                style="@style/Preference"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/deleted"
                android:drawableStart="@drawable/delete"
                android:drawablePadding="16dp" />

            <TextView
                android:id="@+id/GoToReminders"
                style="@style/Preference"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/reminders"
                android:drawableStart="@drawable/notifications"
                android:drawablePadding="16dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider" />

            <TextView
                style="@style/PreferenceHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/security" />

            <include
                android:id="@+id/BackupPassword"
                layout="@layout/preference" />

            <include
                android:id="@+id/SecureFlag"
                layout="@layout/preference" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider" />

            <TextView
                style="@style/PreferenceHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings" />

            <TextView
                android:id="@+id/ImportSettings"
                style="@style/Preference"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/import_settings" />

            <TextView
                android:id="@+id/ExportSettings"
                style="@style/Preference"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/export_settings" />

            <TextView
                android:id="@+id/ResetSettings"
                style="@style/Preference"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/reset_settings" />

            <include
                android:id="@+id/DataInPublicFolder"
                layout="@layout/preference" />

            <include
                android:id="@+id/AutoSaveAfterIdle"
                layout="@layout/preference_stepper" />

            <TextView
                android:id="@+id/ClearData"
                style="@style/Preference"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/clear_data" />
        </LinearLayout>

        <!-- About category (page-like) -->
        <LinearLayout
            android:id="@+id/SectionAbout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:visibility="gone">

            <ImageView
                android:id="@+id/AboutAppIcon"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_marginTop="32dp"
                android:src="@mipmap/memox"
                android:contentDescription="@string/app_name" />

            <TextView
                android:id="@+id/VersionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?android:attr/textColorSecondary" />

            <TextView
                android:id="@+id/AuthorLink"
                style="@style/Preference"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/about_author" />

            <TextView
                android:id="@+id/SourceCode"
                style="@style/Preference"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/source_code" />

            <TextView
                android:id="@+id/ViewLogs"
                style="@style/Preference"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/view_logs" />
        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
